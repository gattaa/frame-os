# Home Assistant secrets template.
# Copy to ha/secrets.yaml (gitignored) and fill in real values.
# Reference these from snippets with the !secret tag, e.g. password: !secret fully_kiosk_password

# --- Fully Kiosk REST fallback ---
# ONLY needed if you use the commented rest_command block in packages/frame.yaml
# instead of the Fully Kiosk integration. The integration is preferred and needs
# none of this.
fully_kiosk_base: "http://192.168.1.50:2323"
fully_kiosk_password: "your-fully-remote-admin-password"

# --- Reference only (not consumed by Home Assistant) ---
# The PWA's long-lived token + base URL live in frame/.env as VITE_HA_TOKEN /
# VITE_HA_BASE_URL — NOT in Home Assistant. Kept here so you have one place to
# jot them down while setting up.
frame_ha_base_url: "https://ha.example.com"
frame_ha_token: "paste-long-lived-token-here"
