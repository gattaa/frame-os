# Home Assistant secrets template.
# Copy to ha/secrets.yaml (gitignored) and fill in real values.
# Reference these from snippets with the !secret tag, e.g. token: !secret ha_token

# Long-lived access token the frame/ PWA uses to read HA state.
frame_ha_token: change-me

# Base URL of the self-hosted Home Assistant on the local network.
frame_ha_base_url: http://homeassistant.local:8123
