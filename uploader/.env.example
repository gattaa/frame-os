# uploader/ — FastAPI sidecar config. Copy to .env (gitignored) and fill in.
# (docker-compose.yml sets these via `environment:`; this file is for running
# the sidecar directly, e.g. `python app.py`.)

# Where the sidecar drops raw uploads. Must be the SAME incoming/ folder the
# pipeline processor watches.
INCOMING_DIR=../data/incoming

# Max accepted upload size, in MB.
MAX_UPLOAD_MB=25

# CORS allowlist — comma-separated origins. Lock this to your HA origin in
# production, e.g. https://ha.example.com . "*" allows any origin.
ALLOWED_ORIGINS=*

# Optional shared secret. If set, the Lovelace card must send the same value
# as the X-Upload-Token header. Leave empty to rely on the reverse proxy.
UPLOAD_TOKEN=

# Bind address/port when running directly (uvicorn).
UPLOADER_HOST=0.0.0.0
UPLOADER_PORT=8077
