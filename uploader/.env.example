# uploader/ — FastAPI sidecar config. Copy to .env (gitignored) and fill in.

# Where the sidecar drops raw uploads. Must be the shared incoming/ folder.
INCOMING_DIR=../data/incoming

# Sidecar bind address/port (local network only).
UPLOADER_HOST=0.0.0.0
UPLOADER_PORT=8077

# Shared secret the Lovelace card sends to authorize uploads.
UPLOAD_TOKEN=change-me
