# frame/ PWA config. Copy to .env (gitignored) for a real device build.
# In `vite dev` everything defaults to mock mode, so none of these are needed
# to run the slideshow against pipeline mock data.

# Force mock mode in a production build (otherwise mock = dev only).
VITE_USE_MOCK=false

# --- Home Assistant ---
VITE_HA_BASE_URL=http://homeassistant.local:8123
# Long-lived access token (never commit a real one).
VITE_HA_TOKEN=
# Entity IDs (override the placeholders in config.ts).
VITE_HA_BATTERY_PCT=sensor.home_battery_level
VITE_HA_POWER_NOW=sensor.grid_power
VITE_HA_ENERGY_TODAY=sensor.solar_energy_today
VITE_HA_CLIMATE_AC=climate.living_room
# Day/night source of truth (from the ha/ package). The PWA themes off this.
VITE_HA_NIGHT_MODE=input_boolean.frame_night_mode

# --- Fully Kiosk (screen control) ---
VITE_FULLY_ENABLED=false
VITE_FULLY_KIOSK_BASE=http://127.0.0.1:2323
VITE_FULLY_PASSWORD=

# --- Data paths (served at /data/* in dev; set for the device otherwise) ---
VITE_MANIFEST_URL=/data/manifest.json
VITE_PHOTOS_BASE=/data/photos
VITE_MOCK_ENTITIES_URL=/data/mock-entities.json

# --- Slideshow ---
VITE_KEN_BURNS=true
# How often (ms) to re-fetch manifest.json so photos added after boot appear
# without a reload. Default 60000.
VITE_MANIFEST_REFRESH_MS=60000
