# frame/ PWA config. Copy to .env (gitignored) for a real device build.
# In `vite dev` everything defaults to mock mode, so none of these are needed
# to run the slideshow against pipeline mock data.

# Force mock mode in a production build (otherwise mock = dev only).
VITE_USE_MOCK=false

# --- Home Assistant / frame-uploader ---
# HA_URL, HA_TOKEN, the battery/power/energy/climate entity IDs, and the
# frame-uploader add-on's URL + upload_token (for the gallery's favourite
# toggle) are NOT here: dist/ is committed to a public repo, so anything
# build-time-injected (env vars included) is publicly visible. Those values
# are instead read at runtime from runtime-config.json, which lives only on
# the HA box and is never committed. See runtime-config.example.json and the
# README.
#
# Day/night source of truth (from the ha/ package) is the one HA entity ID
# still safe to bake in — it's not sensitive, just an entity name.
VITE_HA_NIGHT_MODE=input_boolean.frame_night_mode

# --- Kiosk panel backend (brightness / screen wake / force refresh) ---
# wallpanel | fully | none
VITE_PANEL_BACKEND=none
VITE_WALLPANEL_BASE=http://127.0.0.1:2971
# Legacy Fully Kiosk REST API, only used when VITE_PANEL_BACKEND=fully.
VITE_FULLY_KIOSK_BASE=http://127.0.0.1:2323
VITE_FULLY_PASSWORD=

# --- Data paths ---
# Left unset: PATHS in config.ts defaults these to <base>manifest.json etc.,
# which resolves correctly whether served from domain root (dev) or HA's
# /local/frame/ (prod, see vite.config.ts). Only override if serving data
# from a different host than the app itself.

# --- Slideshow ---
# How often (ms) to re-fetch manifest.json so photos added after boot appear
# without a reload. Default 60000.
VITE_MANIFEST_REFRESH_MS=60000
