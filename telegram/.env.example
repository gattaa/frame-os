# telegram/ — bot config. Copy to .env (gitignored) and fill in.

# Token from @BotFather.
TELEGRAM_BOT_TOKEN=change-me

# Comma-separated allowlist of chat IDs permitted to send photos.
TELEGRAM_ALLOWED_CHAT_IDS=

# Where the bot drops raw photos. Must be the shared incoming/ folder.
INCOMING_DIR=../data/incoming
